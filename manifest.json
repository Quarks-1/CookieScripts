{
  "manifest_version": 3,
  "name": "CookieScripts",
  "version": "0.1.14",
  "description": "Auto-open allowlisted links from Discord web channels.",
  "permissions": [
    "storage",
    "tabs",
    "windows",
    "sidePanel"
  ],
  "host_permissions": [
    "https://discord.com/*",
    "https://api.github.com/*",
    "https://www.target.com/*",
    "https://target.com/*",
    "https://carts.target.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/channels/*"
      ],
      "js": [
        "extension/content/discord.ts"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.target.com/*",
        "https://target.com/*"
      ],
      "js": [
        "extension/content/retailer.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "extension/background/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "ui/sidepanel/index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "injected/cart-probe.js"
      ],
      "matches": [
        "https://www.target.com/*",
        "https://target.com/*"
      ]
    }
  ]
}
