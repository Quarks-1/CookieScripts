{
  "manifest_version": 3,
  "name": "CookieScripts",
  "version": "0.1.5",
  "description": "Auto-open allowlisted links from Discord web channels.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://discord.com/*",
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/channels/*"
      ],
      "js": [
        "extension/content/discord.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "extension/background/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "ui/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
