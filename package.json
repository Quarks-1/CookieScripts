{
  "name": "cookiescripts",
  "private": true,
  "version": "0.1.33",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "package": "npm run build && node -e \"const v=require('./manifest.json').version; require('child_process').execSync('cd dist && zip -r ../cookiescripts-'+v+'.zip .', {stdio:'inherit'})\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:discord": "vitest run tests/discord",
    "test:target": "vitest run tests/target",
    "test:walmart": "vitest run tests/walmart",
    "test:core": "vitest run tests/core",
    "lint": "eslint extension ui tests"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.11",
    "@types/chrome": "^0.0.313",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.6.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
